{
  "name": "language-learner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Korean trainer with browser immersion",
  "scripts": {
    "learner:start": "tsx apps/cli/src/index.ts start",
    "learner:status": "tsx apps/cli/src/index.ts status",
    "learner:daemon": "tsx apps/daemon/src/index.ts",
    "learner:reminders:install": "tsx scripts/install-reminders.ts",
    "learner:export": "tsx apps/cli/src/index.ts export",
    "learner:docs:sync": "tsx apps/cli/src/index.ts docs:sync",
    "learner:import": "tsx apps/cli/src/index.ts import",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "better-sqlite3": "^12.4.1",
    "commander": "^14.0.2",
    "fastify": "^5.6.1",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
